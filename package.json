{
  "name": "koffeeia-complete",
  "version": "2.0.0",
  "description": "تطبيق إدارة الطوابير الذكي — نسخة كاملة",
  "main": "App.js",
  "scripts": {
    "start":          "expo start",
    "android":        "expo run:android",
    "ios":            "expo run:ios",
    "web":            "expo start --web",
    "build:apk":      "eas build -p android --profile preview",
    "build:aab":      "eas build -p android --profile production",
    "build:ios":      "eas build -p ios --profile production",
    "build:all":      "eas build --platform all",
    "submit:android": "eas submit -p android",
    "submit:ios":     "eas submit -p ios"
  },
  "dependencies": {
    "expo":                           "~51.0.0",
    "expo-status-bar":                "~1.12.1",
    "expo-av":                        "~14.0.0",
    "expo-speech":                    "~12.0.0",
    "expo-camera":                    "~15.0.0",
    "expo-barcode-scanner":           "~13.0.0",
    "expo-notifications":             "~0.28.0",
    "expo-linking":                   "~6.3.0",
    "expo-sharing":                   "~12.0.0",
    "expo-font":                      "~12.0.0",
    "expo-splash-screen":             "~0.27.0",
    "expo-haptics":                   "~13.0.0",
    "expo-location":                  "~17.0.0",
    "expo-secure-store":              "~13.0.0",
    "react":                          "18.2.0",
    "react-native":                   "0.74.0",
    "react-native-qrcode-svg":        "^6.3.0",
    "react-native-svg":               "15.2.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "react-native-maps":              "1.14.0",
    "socket.io-client":               "^4.7.5",
    "axios":                          "^1.7.2"
  },
  "devDependencies": {
    "@babel/core":  "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript":   "~5.3.3"
  },
  "private": true
}

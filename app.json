{
  "expo": {
    "name": "Koffeeia",
    "slug": "koffeeia",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07070F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.koffeeia.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج الكاميرا لمسح رمز QR",
        "NSMicrophoneUsageDescription": "نحتاج الميكروفون للرسائل الصوتية",
        "NSLocationWhenInUseUsageDescription": "نستخدم موقعك لإيجاد الأماكن القريبة"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07070F"
      },
      "package": "com.koffeeia.app",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-camera",
      "expo-barcode-scanner",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C8963E"
        }
      ]
    ],
    "extra": {
      "eas": {
"projectId": "ef445889-a2f4-4a8e-a9c3-a10aa6d545cf"      }
    }
  }
}
